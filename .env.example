# ── IBKR ──────────────────────────────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497               # 7497 = paper | 7496 = live
IBKR_CLIENT_ID=1

# ── Trading mode ───────────────────────────────────────────────────────────────
TRADING_MODE=paper           # "paper" or "live" — change explicitly when ready

# ── Risk limits ────────────────────────────────────────────────────────────────
# Swing trading: bigger, longer-held positions, fewer of them.
MAX_POSITION_SIZE_USD=3000
MAX_DAILY_LOSS_USD=1500
MAX_OPEN_POSITIONS=8

# ── Market scanner ─────────────────────────────────────────────────────────────
# Comma-separated list of symbols to watch
WATCHLIST=AAPL,MSFT,NVDA,SPY
# Screener: america, crypto, forex, cfd
TV_SCREENER=america
# Exchange hint for TradingView screener / MCP (SPY uses AMEX automatically)
TV_EXCHANGE=NASDAQ
# Daily bars to fetch from screener (close[0]=today, close[1]=yesterday, …). Max 200.
TV_HISTORY_DAYS=60
# How often to run the scan loop (seconds). Swing patterns run on daily/weekly
# bars, so there's no need to poll every minute — 3600 = once an hour.
SCAN_INTERVAL_SECONDS=3600
# How many symbols to scan concurrently. Each worker opens its own MCP session.
SCANNER_CONCURRENCY=10

# ── Vision confirmation ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Set to false to skip visual confirmation (faster, less API cost)
VISION_CONFIRMATION_ENABLED=true
# Minimum indicator confidence (0.0–1.0) required before even running vision check
VISION_MIN_INDICATOR_CONFIDENCE=0.6

# ── Notifications (optional) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
